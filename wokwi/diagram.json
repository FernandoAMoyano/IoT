{
  "version": 1,
  "author": "Fernando Agustín MOYANO",
  "editor": "wokwi",
  "parts": [
    {
      "type": "board-esp32-devkit-c-v4",
      "id": "esp",
      "top": 0,
      "left": 0,
      "attrs": { "env": "micropython-20231227-v1.22.0" }
    },
    {
      "type": "wokwi-photoresistor-sensor",
      "id": "ldr",
      "top": -60,
      "left": 300,
      "attrs": {}
    },
    {
      "type": "wokwi-led",
      "id": "led1",
      "top": 130,
      "left": 310,
      "attrs": { "color": "yellow" }
    },
    {
      "type": "wokwi-resistor",
      "id": "r1",
      "top": 180,
      "left": 310,
      "rotate": 90,
      "attrs": { "value": "220" }
    }
  ],
  "connections": [
    ["esp:TX", "$serialMonitor:RX", "", []],
    ["esp:RX", "$serialMonitor:TX", "", []],

    ["esp:3V3", "ldr:VCC", "red", []],
    ["esp:GND.1", "ldr:GND", "black", []],
    ["ldr:AO", "esp:34", "green", []],

    ["esp:2", "led1:A", "yellow", []],
    ["led1:C", "r1:1", "yellow", []],
    ["r1:2", "esp:GND.2", "black", []]
  ],
  "dependencies": {}
}
